# Required for OpenAI calls.
OPENAI_API_KEY=

# Default model used by BrainConfig.
AI_BRAIN_MODEL=gpt-5-nano
AIBRAIN_OPENAI_STREAM_TRANSPORT=http
AIBRAIN_OPENAI_WS_POOL_SIZE=4
AIBRAIN_STREAM_EVENT_QUEUE_MAX=256
AIBRAIN_MODELS_CACHE_TTL_SECONDS=300

# Optional local database path.
# AIBRAIN_DATABASE=brain.sqlite3

# Piper TTS. Leave blank if you only want text/STT.
AIBRAIN_TTS_PROVIDER=piper_process
AIBRAIN_TTS_VOICE=
PIPER_EXE=
PIPER_MODEL=
PIPER_CONFIG=
PIPER_ESPEAK_DATA=
AIBRAIN_TTS_VOICE_ROOTS=
AIBRAIN_TTS_MANIFESTS=

# STT/VAD. Installed by default through the `all` extra.
AIBRAIN_STT_PROVIDER=faster_whisper
AIBRAIN_STT_MODEL=base.en
AIBRAIN_STT_DEVICE=auto
AIBRAIN_STT_COMPUTE_TYPE=auto
AIBRAIN_STT_SAMPLE_RATE=16000
AIBRAIN_STT_CHANNELS=1
AIBRAIN_VAD_PROVIDER=silero
AIBRAIN_VAD_THRESHOLD=0.5

# Heartbeat autonomy.
AIBRAIN_HEARTBEAT_FILE=HEARTBEAT.md
